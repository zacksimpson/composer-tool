{
  "expo": {
    "name": "Composer",
    "slug": "composer-tool",
    "version": "1.0.0-beta.5",
    "orientation": "portrait",
    "scheme": "composer-tool",
    "icon": "./assets/images/icon.png",
    "android": {
      "backgroundColor": "#000000",
      "package": "com.zacksimpson.composer"
    },
    "plugins": [
      "expo-router",
      [
        "expo-font",
        {
          "fonts": ["./assets/fonts/PublicSans-Regular.ttf"]
        }
      ],
      "./plugins/withAndroidConfigChanges",
      "./plugins/withAndroidTheme",
      "./plugins/withDebugApplicationIdSuffix"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "4e59f350-105d-477e-be37-6d6dd44dc875"
      }
    },
    "owner": "zacksimpson"
  }
}
